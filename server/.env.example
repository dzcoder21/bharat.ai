# ═══════════════════════════════════════════════════════════
#   Bharat.AI v4.0 — All AI Providers
#   Copy to .env and add your keys
# ═══════════════════════════════════════════════════════════
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/bharatai
JWT_SECRET=bharat-ai-secret-change-in-production

# ── FREE APIs (recommended) ───────────────────────────────
GROQ_API_KEY=             # console.groq.com — 14,400/day FREE
GEMINI_API_KEY=           # aistudio.google.com — 1500/day FREE
BRAVE_API_KEY=            # api.search.brave.com — 2000/month FREE

# ── PAID APIs (optional) ──────────────────────────────────
ANTHROPIC_API_KEY=        # console.anthropic.com — $5 free credits
OPENAI_API_KEY=           # platform.openai.com

CACHE_TTL=300
